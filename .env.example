# Default AI Provider: openai / anthropic / ollama
DEFAULT_AI_PROVIDER=openai

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/novel_writer.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
